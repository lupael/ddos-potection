# Environment Variables Configuration Example
# Copy this file to .env and update with your values

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
DATABASE_URL=postgresql://ddos_user:ddos_pass@postgres:5432/ddos_platform

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# =============================================================================
# API CONFIGURATION
# =============================================================================
HOST=0.0.0.0
PORT=8000
DEBUG=False

# Security - CHANGE THESE IN PRODUCTION!
SECRET_KEY=your-secret-key-change-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# =============================================================================
# CORS CONFIGURATION
# =============================================================================
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=["http://localhost:3000","https://yourdomain.com"]

# =============================================================================
# NETFLOW/SFLOW/IPFIX PORTS
# =============================================================================
NETFLOW_PORT=2055
SFLOW_PORT=6343
IPFIX_PORT=4739

# =============================================================================
# DETECTION THRESHOLDS
# =============================================================================
# SYN flood threshold (packets per second)
SYN_FLOOD_THRESHOLD=10000

# UDP flood threshold (packets per second)
UDP_FLOOD_THRESHOLD=50000

# Entropy threshold for anomaly detection
ENTROPY_THRESHOLD=3.5

# =============================================================================
# MITIGATION SETTINGS
# =============================================================================
# Enable automatic mitigation
AUTO_MITIGATION=True

# Mitigation duration in seconds
MITIGATION_DURATION=300

# =============================================================================
# EMAIL ALERTS CONFIGURATION
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
ALERT_EMAIL=alerts@yourdomain.com

# =============================================================================
# TELEGRAM ALERTS CONFIGURATION
# =============================================================================
# Get bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Get chat ID from @userinfobot on Telegram
TELEGRAM_CHAT_ID=123456789

# =============================================================================
# PAYMENT GATEWAY CONFIGURATION
# =============================================================================
# Stripe
STRIPE_API_KEY=sk_live_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# PayPal (optional)
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_secret

# =============================================================================
# MONITORING CONFIGURATION
# =============================================================================
PROMETHEUS_PORT=9090

# =============================================================================
# BGP BLACKHOLING (RTBH) CONFIGURATION
# =============================================================================
# See docs/BGP-RTBH.md for complete setup instructions

# Enable BGP blackholing support
BGP_ENABLED=false

# BGP daemon to use: exabgp, frr, or bird
# ExaBGP: Easiest to integrate, Python-based, designed for automation
# FRR: Full-featured routing suite, production-ready
# BIRD: Lightweight, high-performance routing daemon
BGP_DAEMON=exabgp

# Blackhole next-hop address (standard is 192.0.2.1 per RFC 5635)
# This is a documentation IP that tells routers to drop the traffic
BGP_BLACKHOLE_NEXTHOP=192.0.2.1

# Blackhole community tag (standard is 65535:666 per RFC 7999)
# Some ISPs use custom communities - check with your upstream provider
BGP_BLACKHOLE_COMMUNITY=65535:666

# ExaBGP-specific configuration
# Named pipe for sending commands to ExaBGP
EXABGP_CMD_PIPE=/var/run/exabgp.cmd

# FRR-specific configuration
# Path to vtysh command-line interface
FRR_VTYSH_CMD=/usr/bin/vtysh

# BIRD-specific configuration
# Path to BIRD control socket
BIRD_CONTROL_SOCKET=/var/run/bird/bird.ctl

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# =============================================================================
# ROUTER INTEGRATION
# =============================================================================
# MikroTik default credentials (change these!)
MIKROTIK_DEFAULT_USER=admin
MIKROTIK_DEFAULT_PASS=password

# =============================================================================
# RATE LIMITING
# =============================================================================
# API rate limit (requests per minute)
API_RATE_LIMIT=100

# =============================================================================
# FILE UPLOAD LIMITS
# =============================================================================
MAX_UPLOAD_SIZE=10485760  # 10MB in bytes

# =============================================================================
# SESSION CONFIGURATION
# =============================================================================
SESSION_TIMEOUT=3600  # 1 hour in seconds

# =============================================================================
# FEATURE FLAGS
# =============================================================================
ENABLE_BGP_BLACKHOLE=True
ENABLE_FLOWSPEC=True
ENABLE_GEO_BLOCKING=True
ENABLE_MACHINE_LEARNING=False

# =============================================================================
# EXTERNAL SERVICES (Optional)
# =============================================================================
# MaxMind GeoIP database path
GEOIP_DATABASE_PATH=/usr/share/GeoIP/GeoLite2-City.mmdb

# Elasticsearch (for log indexing)
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200

# =============================================================================
# BACKUP CONFIGURATION
# =============================================================================
BACKUP_ENABLED=True
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM
BACKUP_RETENTION_DAYS=7
BACKUP_PATH=/var/backups/ddos-platform

# =============================================================================
# PACKET CAPTURE ENGINES
# =============================================================================

# PCAP Attack Fingerprint Capture
PCAP_CAPTURE_ATTACKS=true
PCAP_STORAGE_PATH=/var/log/ddos/fingerprints
PCAP_MAX_SIZE=100MB
PCAP_MAX_DURATION=300  # seconds
PCAP_RETENTION_DAYS=30
PCAP_TRIGGER_ON_ALERT=true
PCAP_MIN_PPS=10000

# AF_PACKET Configuration (Recommended for Linux 10-40 Gbps)
AF_PACKET_ENABLED=false
AF_PACKET_INTERFACE=eth0
AF_PACKET_FANOUT=true
AF_PACKET_FANOUT_TYPE=hash
AF_PACKET_RING_SIZE=2048
AF_PACKET_VLAN_UNTAG=true
AF_PACKET_WORKERS=4

# AF_XDP Configuration (Ultra high-speed 40-100+ Gbps)
AF_XDP_ENABLED=false
AF_XDP_INTERFACE=eth0
AF_XDP_ZERO_COPY=true
AF_XDP_QUEUE_SIZE=4096
AF_XDP_MODE=native

# VLAN Support
SFLOW_VLAN_UNTAG=true
AF_PACKET_VLAN_IDS=100,200,300

# =============================================================================
# IPv6 SUPPORT
# =============================================================================
IPV6_ENABLED=true
IPV6_DETECTION=true
IPV6_MITIGATION=true

# =============================================================================
# KAFKA INTEGRATION (Data Export)
# =============================================================================
KAFKA_ENABLED=false
KAFKA_BOOTSTRAP_SERVERS=kafka1:9092,kafka2:9092,kafka3:9092
KAFKA_TOPIC_FLOWS=ddos.flows
KAFKA_TOPIC_ALERTS=ddos.alerts
KAFKA_TOPIC_MITIGATIONS=ddos.mitigations
KAFKA_FORMAT=json  # json or protobuf
KAFKA_COMPRESSION=gzip
KAFKA_BATCH_SIZE=1000

# =============================================================================
# CLICKHOUSE INTEGRATION (Analytics)
# =============================================================================
CLICKHOUSE_ENABLED=false
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=9000
CLICKHOUSE_DATABASE=ddos_analytics
CLICKHOUSE_USER=ddos
CLICKHOUSE_PASSWORD=secure_password

# =============================================================================
# INFLUXDB INTEGRATION (Time-Series Metrics)
# =============================================================================
INFLUXDB_ENABLED=false
INFLUXDB_HOST=influxdb
INFLUXDB_PORT=8086
INFLUXDB_DATABASE=ddos_metrics
INFLUXDB_USER=ddos
INFLUXDB_PASSWORD=secure_password

# InfluxDB 2.x (if using 2.x instead of 1.x)
INFLUXDB_V2=false
INFLUXDB_ORG=my-org
INFLUXDB_BUCKET=ddos-metrics
INFLUXDB_TOKEN=your-influxdb-token

# =============================================================================
# GRAPHITE INTEGRATION (Metrics)
# =============================================================================
GRAPHITE_ENABLED=false
GRAPHITE_HOST=graphite
GRAPHITE_PORT=2003
GRAPHITE_PREFIX=ddos.protection

# =============================================================================
# MONGODB/FERRETDB INTEGRATION (Flexible Schema)
# =============================================================================
MONGODB_ENABLED=false
MONGODB_HOST=ferretdb  # or mongodb
MONGODB_PORT=27017
MONGODB_DATABASE=ddos_platform

# FerretDB Configuration (PostgreSQL-backed MongoDB)
FERRETDB_POSTGRESQL_URL=postgresql://user:pass@postgres:5432/ferretdb

# =============================================================================
# GOBGP CONFIGURATION (Alternative to ExaBGP)
# =============================================================================
# GoBGP is recommended for better performance
GOBGP_HOST=localhost
GOBGP_PORT=50051
GOBGP_GRPC_TIMEOUT=10

# =============================================================================
# PER-SUBNET THRESHOLDS (Hostgroups)
# =============================================================================
# Configure different thresholds for different network segments
# See API documentation for creating hostgroups via API

# =============================================================================
# SCRIPT TRIGGERS (Custom Actions)
# =============================================================================
TRIGGER_SCRIPTS_ENABLED=false
TRIGGER_SCRIPT_PATH=/opt/ddos-protection/scripts/triggers
TRIGGER_ON_ALERT=true
TRIGGER_ON_MITIGATION=true
TRIGGER_ON_RESOLVE=true
SCRIPT_TIMEOUT=30

# =============================================================================
# ADDITIONAL ALERT CHANNELS
# =============================================================================
# Slack
SLACK_ENABLED=false
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK

# PagerDuty
PAGERDUTY_ENABLED=false
PAGERDUTY_API_KEY=your_api_key

# SMS (Twilio)
SMS_ENABLED=false
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+1234567890

